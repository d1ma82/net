    "version": "0.2.0",
    "configurations": [
        {
            "name": "cl.exe - Сборка и отладка активного файла",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": ["opencv_core453.lib", "opencv_imgcodecs453.lib", "opencv_imgproc453.lib",
                 "opencv_highgui453.lib"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "console": "externalTerminal",
            "preLaunchTask": "C/C++: cl.exe сборка активного файла"
        }
    ]
}